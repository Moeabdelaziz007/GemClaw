{
  "entities": {
    "Agent": {
      "title": "Agent",
      "description": "An AI agent with specific personality and capabilities",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "systemPrompt": { "type": "string" },
        "voiceName": { "type": "string" },
        "seed": { "type": "string" },
        "users": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["id", "name", "role", "systemPrompt", "voiceName", "ownerId"]
    },
    "History": {
      "title": "History",
      "description": "A message in a chat session history",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "text"]
    },
    "AgentMemory": {
      "title": "Agent Memory",
      "description": "Long-term memory for the agent using vector embeddings.",
      "type": "object",
      "properties": {
        "agentId": { "type": "string" },
        "content": { "type": "string" },
        "embedding": { "type": "array", "description": "Vector embedding for semantic search" },
        "importance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["agentId", "content", "embedding", "createdAt"]
    }
  },
  "firestore": {
    "/agents/{agentId}": {
      "schema": "Agent",
      "description": "Collection of AI agents"
    },
    "/agents/{agentId}/history/{messageId}": {
      "schema": "History",
      "description": "Memory of conversations for each agent"
    },
    "/agent_memories/{memoryId}": {
      "schema": "AgentMemory",
      "description": "Long-term semantic memory for agents"
    }
  }
}
