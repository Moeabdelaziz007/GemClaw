rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }
    function uidUnchanged() {
      return !('ownerId' in request.resource.data) || request.resource.data.ownerId == request.auth.uid;
    }
    function uidNotModified() {
      return !('ownerId' in request.resource.data) || request.resource.data.ownerId == resource.data.ownerId;
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }
    
    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return hasOnlyAllowedFields(['email', 'displayName', 'photoURL', 'createdAt']) &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.createdAt is timestamp &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500));
    }

    function isValidAgent(data) {
      return hasOnlyAllowedFields(['ownerId', 'name', 'description', 'systemPrompt', 'voiceName', 'createdAt']) &&
             data.ownerId is string && data.ownerId.size() > 0 && data.ownerId.size() < 50 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.systemPrompt is string && data.systemPrompt.size() > 0 && data.systemPrompt.size() < 10000 &&
             data.voiceName is string && data.voiceName.size() > 0 && data.voiceName.size() < 50 &&
             data.createdAt is timestamp &&
             (!('description' in data) || (data.description is string && data.description.size() <= 1000));
    }

    function isValidSkill(data) {
      return hasOnlyAllowedFields(['agentId', 'name', 'description', 'endpoint', 'isActive', 'createdAt']) &&
             data.agentId is string && data.agentId.size() > 0 && data.agentId.size() < 50 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 1000 &&
             isValidUrl(data.endpoint) && data.endpoint.size() < 500 &&
             data.isActive is bool &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(userId);
    }

    match /agents/{agentId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && uidUnchanged() && isValidAgent(request.resource.data);
      allow update: if isDocOwner() && uidNotModified() && isValidAgent(request.resource.data) &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }

    match /skills/{skillId} {
      // For skills, we allow read if the user owns the parent agent.
      // Since we don't store ownerId on skill directly, we check the agent document.
      allow read: if isAuthenticated() && get(/databases/$(database)/documents/agents/$(resource.data.agentId)).data.ownerId == request.auth.uid;
      allow create: if isAuthenticated() && 
                    get(/databases/$(database)/documents/agents/$(request.resource.data.agentId)).data.ownerId == request.auth.uid &&
                    isValidSkill(request.resource.data);
      allow update: if isAuthenticated() && 
                    get(/databases/$(database)/documents/agents/$(resource.data.agentId)).data.ownerId == request.auth.uid &&
                    get(/databases/$(database)/documents/agents/$(request.resource.data.agentId)).data.ownerId == request.auth.uid &&
                    isValidSkill(request.resource.data) &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && get(/databases/$(database)/documents/agents/$(resource.data.agentId)).data.ownerId == request.auth.uid;
    }
  }
}
