# 🧬 Gemigram AIOS — Environment Configuration Template
# Copy this to .env.local and fill in the values.

# Firebase Configuration (Publicly Exposed)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Gemini API (Server-side only — Secret)
# Used in /api/gemini/generate
GEMINI_API_KEY=

# Legacy NextAuth Configuration (Deprecated — Scheduled for Removal in Task-03)
# These are kept temporarily for backwards compatibility during migration.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_SECRET=

# 🛡️ Sovereign Security Note: 
# NEVER commit .env.local to version control.
# ALL production keys must be managed via Cloud Console Secret Manager.
