# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# FIREBASE_FUNCTION_URL: The URL of the Firebase Cloud Function bridge.
FIREBASE_FUNCTION_URL=

# Public runtime networking configuration.
# Local bridge defaults to http://127.0.0.1:9999 only on localhost when not explicitly set.
NEXT_PUBLIC_LOCAL_BRIDGE_ORIGIN=
# Explicitly enable probing /status before switching linkType to bridge.
NEXT_PUBLIC_ENABLE_BRIDGE_CHECK=false
# Explicitly enable local bridge execution outside localhost.
NEXT_PUBLIC_ENABLE_LOCAL_BRIDGE=false
# Optional backend-managed telemetry endpoint. Leave unset to disable remote telemetry.
NEXT_PUBLIC_TELEMETRY_ENDPOINT=
# Polling is disabled by default; set a positive millisecond value to opt in.
NEXT_PUBLIC_TELEMETRY_POLL_MS=0
# Network timeout controls in milliseconds.
NEXT_PUBLIC_BRIDGE_TIMEOUT_MS=1500
NEXT_PUBLIC_TELEMETRY_TIMEOUT_MS=2500
NEXT_PUBLIC_REMOTE_FETCH_TIMEOUT_MS=4000
# Optional override for workspace cloud execution endpoint.
NEXT_PUBLIC_FUNCTION_URL=
