# 🧬 GEMIGRAM v4.0 — Environment Variables Template
# Copy this to .env and fill in the values.
# NEVER COMMIT YOUR .ENV FILE TO VERSION CONTROL.

# --- GOOGLE AI / GEMINI ---
# Move to server-side only in v4.0
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# --- GITHUB MCP (OAuth) ---
# Client ID can be public, but Secret MUST be server-side only.
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# --- FIREBASE CONFIG (Client-Side) ---
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# --- AETHER LOCAL BRIDGE ---
# For connecting local dev to cloud agents
AETHER_BRIDGE_SECRET=your_secret_here
AETHER_API_URL=http://localhost:3000/api

# --- OPTIONAL: ANALYTICS / MONITORING ---
NEXT_PUBLIC_SENTRY_DSN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
